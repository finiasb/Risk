<Window x:Class="Risk.AlegereJucatoriWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configurare Joc" Height="200" Width="350" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#1E1E1E" Foreground="White">

    <Grid Margin="0,20,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Selectați numărul de jucători (2 - 6):" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,-6,0,15"/>
        <ComboBox x:Name="JucatoriComboBox" Grid.Row="1" Width="100" Height="30" FontSize="14" VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
            <ComboBoxItem Content="2" IsSelected="True"/>
            <ComboBoxItem Content="3"/>
            <ComboBoxItem Content="4"/>
            <ComboBoxItem Content="5"/>
            <ComboBoxItem Content="6"/>
        </ComboBox>
        <Button Grid.Row="2" Content="Start Joc" Width="120" Height="30" Background="#2D2D2D" Foreground="White" FontWeight="Bold" Click="StartJoc_Click" Margin="0,0,0,15"/>
    </Grid>
</Window>